# Active Communities (Richmond Hill) login credentials
AC_USERNAME=your_email@example.com
AC_PASSWORD=your_password

# Email notification settings (Gmail recommended)
# For Gmail: enable "App Passwords" in your Google Account security settings
# and use the generated 16-character app password here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# Polling interval in minutes (default: 30)
POLL_INTERVAL_MINUTES=30

# Optional: filter by specific days (comma-separated: Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday)
# Leave blank to check all days
TARGET_DAYS=

# Optional: filter by time range (24h format, e.g. 06:00-22:00)
# Leave blank to check all times
TARGET_TIME_FROM=
TARGET_TIME_TO=
